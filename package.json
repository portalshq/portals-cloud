{
  "name": "portals-platform",
  "private": true,
  "version": "0.1.0",
  "description": "Capability-first infrastructure platform for composable entertainment channels. ",
  "workspaces": [
    "frontend",
    "packages/*",
    "packages/stubs/*",
    "lib/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "prepare": "test -d .git && husky || echo 'Skipping Husky (Not a local Git repo)'",
    "local-version-script": "npx changeset version",
    "local-publish-script": "turbo build && npm publish --workspaces --if-needed --provenance"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "@changesets/cli": "^2.27.0",
    "turbo": "^2.0.0",
    "typescript": "^5.5.0"
  },
  "packageManager": "npm@10.0.0"
}
